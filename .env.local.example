# NextAuth Configuration
NEXTAUTH_SECRET=your_random_secret_key_min_32_characters_long_here
NEXTAUTH_URL=http://localhost:3000

# Database (if using)
DATABASE_URL=your_database_url

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Cloud Storage Configuration
# Using Base64 encoding for consistency across all environments
# (local development, staging, production)

GCP_PROJECT_ID=your_project_id
GCP_SERVICE_ACCOUNT_B64=your_base64_encoded_json_here
GCS_BUCKET_NAME=your_bucket_name

# To generate base64:
# macOS/Linux: cat credentials/your_file.json | base64
# Windows: [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("credentials/your_file.json")) | Set-Clipboard

# LINE OA Integration
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_OA_WEBHOOK_URL=https://your-domain.com/api/line/complain

# NOTE: For Vercel Deployment, set environment variables in the Vercel Dashboard
# Do not add actual secrets to this file!
# Reference: https://vercel.com/docs/projects/environment-variables
